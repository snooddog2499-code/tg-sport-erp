# ========================================
# TG Sport ERP — Environment Variables
# Copy this file to .env.local and fill in values
# ========================================

# ---- Supabase Postgres (REQUIRED) ----
# จาก Supabase Dashboard → Project Settings → Database → Connection string
# ใช้ Connection pooling (Transaction mode, port 6543) สำหรับ runtime
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) สำหรับ migration เท่านั้น
# จำเป็นเพราะ pgbouncer ไม่รองรับ DDL จาก drizzle-kit
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ---- Supabase Storage (REQUIRED) ----
# จาก Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key — มีสิทธิ์เต็ม ใช้ฝั่ง server เท่านั้น
# Storage uploads ใช้ key นี้ (bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ชื่อ bucket — สร้างใน Supabase Storage ก่อน (set เป็น public)
SUPABASE_STORAGE_BUCKET=uploads

# ---- LINE Messaging API (Optional) ----
# ถ้าจะส่งลิงก์อนุมัติลายทาง LINE ให้ลูกค้าอัตโนมัติ
# จาก https://developers.line.biz → Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=
